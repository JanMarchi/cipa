{
  "name": "CIPA Eleitoral — primeiros testes",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {}
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "CIPA Eleitoral",
      "onAutoForward": "openPreview",
      "visibility": "private"
    }
  },
  "postCreateCommand": "bash .devcontainer/bootstrap.sh",
  "remoteUser": "vscode",
  "hostRequirements": {
    "cpus": 2
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
