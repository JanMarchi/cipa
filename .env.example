DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
POSTGRES_OWNER_PASSWORD=change-me-owner
CIPA_APP_PASSWORD=change-me-app
DATABASE_URL=postgresql://cipa_app:change-me-app@postgres:5432/cipa
DATABASE_MIGRATION_URL=postgresql://cipa_owner:change-me-owner@postgres:5432/cipa
REDIS_URL=redis://redis:6379/0
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=CIPA Eleitoral <nao-responda@example.invalid>
# One or more URL-safe Fernet keys separated by commas. Generate outside source control.
MFA_ENCRYPTION_KEYS=
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_TRUSTED_PROXY_COUNT=0
DJANGO_CAPTURE_SECURITY_IP=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
SENTRY_DSN=
